# Bridge Server Configuration

# Server
PORT=3002
HOST=0.0.0.0

# Database
DATABASE_PATH=./data/sessions.db

# Claude Code CLI
CLAUDE_CODE_PATH=/usr/local/bin/claude-code
CURSOR_PATH=/usr/local/bin/cursor

# Session Management
MAX_SESSIONS=10
SESSION_TIMEOUT_MS=3600000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/bridge-server.log

# CORS
CORS_ORIGIN=*
