# Complete Docker image with Claude Code CLI and Bridge Server
# For Kubernetes deployments

FROM node:22-bookworm

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    git \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Verify Claude Code installation
RUN claude --version || echo "Claude Code installed"

# Set up bridge server
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies (including dev for build)
RUN npm ci

# Copy source code
COPY tsconfig.json ./
COPY src ./src

# Build TypeScript
RUN npm run build

# Remove dev dependencies
RUN npm prune --production

# Create data directory for SQLite database
RUN mkdir -p /data

# Create projects directory (for mounting project volumes)
RUN mkdir -p /projects

# Set environment variables
ENV NODE_ENV=production
ENV DATABASE_PATH=/data/sessions.db
ENV CLAUDE_CODE_PATH=claude
ENV HOST=0.0.0.0
ENV PORT=3002
ENV MAX_SESSIONS=100
ENV SESSION_TIMEOUT_MS=3600000
ENV LOG_LEVEL=info

# Claude Code configuration
ENV ANTHROPIC_API_KEY=""
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Expose port
EXPOSE 3002

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3002/health || exit 1

# Run the bridge server
CMD ["node", "dist/index.js"]
